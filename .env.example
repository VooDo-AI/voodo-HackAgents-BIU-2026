# Voodo runtime config. Copy to `.env` and fill in real values.
# Never commit the resulting .env (it's already in .gitignore).

# ── LLM provider — OpenRouter (https://openrouter.ai) ──
# Sign up, create a key at https://openrouter.ai/keys, paste it below.
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=
# Any vision-capable, tool-calling model on OpenRouter works. Defaults:
LLM_MODEL=qwen/qwen3-vl-235b-a22b-thinking

# ── Postgres + pgvector (docker compose service) ──
POSTGRES_USER=voodo
POSTGRES_PASSWORD=
POSTGRES_DB=voodo
# DATABASE_URL is consumed by the backend when run outside docker.
# Inside the compose network the backend reaches the DB at host `postgres`.
DATABASE_URL=postgresql://voodo:CHANGE_ME@localhost:5432/voodo

# ── Backend (FastAPI) ──
APP_HOST=0.0.0.0
APP_PORT=7860

# ── Agent loop ──
AGENT_MAX_STEPS=15
SIMILARITY_THRESHOLD=0.85

# ── Windows executor shared secret ──
# Generate once with: python -c "import secrets; print(secrets.token_hex(24))"
# Must match what the client-side executor sends (see client/scripts/dev_all.ps1).
EXECUTOR_TOKEN=

# ── IT & Admin auth ──
IT_USERNAME=admin
IT_PASSWORD=
ADMIN_PASSWORD=

# ── Production mode ──
# Set VOODO_PROD=1 to require non-default values for every secret above.
# Leave blank in local dev.
VOODO_PROD=
